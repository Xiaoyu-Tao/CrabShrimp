# LLM 配置
# Claude:  claude-sonnet-4-6 / claude-opus-4-6
# OpenAI:  gpt-4o / gpt-4o-mini
# 开源:    ollama/llama3
# 代理转发: openai/claude-sonnet-4-6（配合 CRABSHRIMP_API_BASE 使用）
CRABSHRIMP_MODEL=claude-sonnet-4-6

ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# 自定义 API Base（使用 OpenAI 兼容代理时填写，直连官方可删除）
# CRABSHRIMP_API_BASE=https://api.example.com/v1

# ── 资源控制 ──────────────────────────────────────────────────
CRABSHRIMP_STEP_LIMIT=50
CRABSHRIMP_TOKEN_BUDGET=100000

# ── 机制开关（true/false，默认均为 true）─────────────────────
# 关键节点是否触发 Coral-Meeting 多智能体集体审议
CRABSHRIMP_CORAL_MEETING=true
# 是否调用 LLM 进行任务分类（false 则固定为 "general"）
CRABSHRIMP_CLASSIFY=true
# 是否将每步执行写入 JSONL Trace 文件
CRABSHRIMP_TRACE=true
# 是否启用 Tidal-Pool 资源守护（false 则无步数/Token 限制）
CRABSHRIMP_RESOURCE_GUARD=true

# ── 隔离开关（true/false，默认均为 true）─────────────────────
# 上下文隔离：isolated 角色（Critic/Verifier）只看紧邻上一步输出，防锚定偏差
CRABSHRIMP_CONTEXT_ISOLATION=true
# 工作空间隔离：scoped 角色（Executor）获得独立临时目录 /tmp/crabshrimp/<task>/<agent>/
CRABSHRIMP_WORKSPACE_ISOLATION=true
# 执行环境隔离：subprocess 角色（Executor）在隔离子进程中运行命令
CRABSHRIMP_EXEC_ISOLATION=true

# ── v0.3 演化开关 ─────────────────────────────────────────────
# 任务结束后是否从 Trace 提取可复用 Skill 写入知识库
CRABSHRIMP_SKILL_EXTRACTION=true
# 执行前是否将历史最优 Skill 注入 system prompt
CRABSHRIMP_SKILL_INJECTION=true
# Coral-Meeting 拓扑筛选阈值（低于此胜率的 Agent 自动退出会议投票）
CRABSHRIMP_BENCH_THRESHOLD=0.5

# ── Human-in-the-Loop ─────────────────────────────────────────
# 总开关（默认关闭，开启后在三个检查点等待人工确认）
CRABSHRIMP_HITL=false
# 检查点 1：执行计划生成后暂停
CRABSHRIMP_HITL_ON_PLAN=true
# 检查点 2：Coral-Meeting 共识后暂停
CRABSHRIMP_HITL_ON_CRITICAL=true
# 检查点 3：Verifier 判定失败后暂停
CRABSHRIMP_HITL_ON_VERIFY_FAIL=true

# ── v0.4 优化器 ───────────────────────────────────────────────
# 是否在任务结束后运行 Optimizer Agent（分析 Trace，自动改写低效 Prompt）
CRABSHRIMP_OPTIMIZER=false

# ── 显示 ──────────────────────────────────────────────────────
# 是否启用 Rich 实时终端面板（false 则回退为普通日志输出）
CRABSHRIMP_DISPLAY=true

# ── 路径 ──────────────────────────────────────────────────────
CRABSHRIMP_TRACE_DIR=./traces
CRABSHRIMP_DB_PATH=./crabshrimp.db
